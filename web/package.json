{
  "name": "mls-queen-web",
  "version": "1.0.0",
  "description": "Compliance docs chatbot — upload USA, Portugal, Mexico docs and ask questions",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test:compliance": "playwright test",
    "test:compliance:ui": "playwright test --ui",
    "test:compliance:headed": "playwright test --headed",
    "test:compliance:report": "playwright show-report test/reports/playwright",
    "fixtures:generate": "node scripts/generate-fixtures.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.27.0",
    "pdf-parse": "^1.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
